{
	"name": "@noron/dev",
	"version": "0.0.0",
	"private": true,
	"scripts": {
		"mock-benchd": "bun mock-benchd.ts",
		"local-test": "bun local-test.ts",
		"local-test:serve": "bun local-test.ts --serve",
		"local-test:bench": "bun local-test.ts --bench-only",
		"sbc": "./sbc.sh",
		"emulate": "./sbc.sh && ./emulate-local.sh ${BOARD:-rpi4b}",
		"emulate:boot": "./emulate-local.sh ${BOARD:-rpi4b}",
		"emulate:persist": "./emulate-local.sh --persist ${BOARD:-rpi4b}",
		"emulate:fetch": "./emulate.sh --fetch ${BOARD:-rpi4b}",
		"test:img": "./test-img.sh",
		"test:img:quick": "./test-img.sh --skip-build",
		"test:img:shell": "orbctl run -m bench-test bash",
		"iso": "make iso",
		"iso:x64": "make iso ARCH=x64",
		"vm:clean": "make vm-clean",
		"clean": "make clean"
	}
}
