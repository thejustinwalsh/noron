{
	"compilerOptions": {
		"target": "ESNext",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"esModuleInterop": true,
		"strict": true,
		"skipLibCheck": true,
		"declaration": true,
		"declarationMap": true,
		"sourceMap": true,
		"outDir": "dist",
		"rootDir": "src",
		"types": ["bun-types"],
		"jsx": "react-jsx",
		"paths": {
			"@noron/shared": ["../shared/src/index.ts"],
			"@noron/shared/*": ["../shared/src/*"]
		}
	}
}
