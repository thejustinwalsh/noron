FROM debian:12-slim

# Install GitHub Actions runner dependencies
RUN apt-get update && apt-get install -y --no-install-recommends \
    curl \
    ca-certificates \
    git \
    jq \
    sudo \
    unzip \
    libicu72 \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y nodejs \
    && rm -rf /var/lib/apt/lists/*

# Install Bun
RUN curl -fsSL https://bun.sh/install | bash \
    && mv /root/.bun/bin/bun /usr/local/bin/

# Create runner user with sudo access to bench-exec only
RUN useradd -m -s /bin/bash runner \
    && echo "runner ALL=(root) NOPASSWD: /usr/local/bin/bench-exec" >> /etc/sudoers.d/runner \
    && chmod 0440 /etc/sudoers.d/runner

# Install GitHub Actions runner
# Fetches the latest release automatically via the GitHub API.
# RUNNER_ARCH: x64 for amd64, arm64 for aarch64. Auto-detected from platform
# but can be overridden: podman build --build-arg RUNNER_ARCH=arm64
ARG TARGETARCH
ARG RUNNER_ARCH
RUN ARCH="${RUNNER_ARCH:-$(case "${TARGETARCH:-$(dpkg --print-architecture)}" in arm64|aarch64) echo arm64;; *) echo x64;; esac)}" \
    && RUNNER_VERSION=$(curl -fsSL https://api.github.com/repos/actions/runner/releases/latest | jq -r '.tag_name' | sed 's/^v//') \
    && echo "Installing actions-runner ${RUNNER_VERSION} (${ARCH})" \
    && mkdir -p /opt/actions-runner \
    && cd /opt/actions-runner \
    && curl -fsSL "https://github.com/actions/runner/releases/download/v${RUNNER_VERSION}/actions-runner-linux-${ARCH}-${RUNNER_VERSION}.tar.gz" \
    | tar xz \
    && chown -R runner:runner /opt/actions-runner

# Job hooks: acquire/release machine-wide lock
# The compiled binaries are bind-mounted from the host at runtime.
# GitHub Actions requires hook scripts to have a .sh/.ps1/.js extension,
# so we create thin wrappers that exec the binaries.
RUN printf '#!/bin/bash\nexec /usr/local/lib/benchd/hooks/job-started "$@"\n' > /opt/actions-runner/hook-job-started.sh \
    && printf '#!/bin/bash\nexec /usr/local/lib/benchd/hooks/job-completed "$@"\n' > /opt/actions-runner/hook-job-completed.sh \
    && chmod +x /opt/actions-runner/hook-job-started.sh /opt/actions-runner/hook-job-completed.sh
ENV ACTIONS_RUNNER_HOOK_JOB_STARTED=/opt/actions-runner/hook-job-started.sh
ENV ACTIONS_RUNNER_HOOK_JOB_COMPLETED=/opt/actions-runner/hook-job-completed.sh

COPY start.sh /opt/actions-runner/start.sh

USER runner
WORKDIR /opt/actions-runner

ENTRYPOINT ["/opt/actions-runner/start.sh"]
