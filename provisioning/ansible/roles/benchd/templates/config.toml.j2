# benchd configuration
# Generated by Ansible provisioning

# CPU core allocation
isolated_cores = [{{ isolated_cores }}]
housekeeping_core = {{ housekeeping_core }}

# Thermal settings
target_temp_c = 45
thermal_history_size = 300
thermal_poll_interval_ms = 1000
thermal_timeout_ms = 300000

# Paths
socket_path = "{{ benchd_socket }}"
benchmark_slice = "benchmark.slice"
benchmark_cgroup = "/sys/fs/cgroup/benchmark.slice"
bench_tmpfs = "{{ bench_tmpfs_path }}"

# Lock behavior
lock_disconnect_grace_ms = 5000

# Token expiry
token_expiry_hours = 24
