{
	"name": "@noron/setup",
	"version": "0.1.0",
	"private": true,
	"type": "module",
	"scripts": {
		"dev": "bun --watch src/main.ts",
		"build": "bun build ./src/main.ts --compile --outfile dist/bench-setup --target ${BUN_TARGET:-bun-linux-x64}",
		"typecheck": "tsc --noEmit"
	},
"dependencies": {
		"@noron/shared": "workspace:*",
		"ink": "^5",
		"ink-spinner": "^5",
		"ink-text-input": "^6",
		"react": "^18.3"
	},
	"devDependencies": {
		"@types/react": "^18.3",
		"bun-types": "^1.2"
	}
}
