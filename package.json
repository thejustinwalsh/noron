{
	"name": "noron",
	"description": "Dedicated benchmark appliance for GitHub Actions with <0.1% variance",
	"private": true,
	"packageManager": "bun@1.3.5",
	"repository": "thejustinwalsh/noron",
	"license": "MIT",
	"workspaces": ["packages/*", "dev"],
	"scripts": {
		"build": "turbo run build",
		"test": "turbo run test",
		"typecheck": "turbo run typecheck",
		"lint": "biome check .",
		"lint:fix": "biome check --write .",
		"changeset": "changeset",
		"changeset:version": "changeset version",
		"collect-dist": "turbo run build --filter=@noron/iso...",
		"release": "bun run build && changeset publish"
	},
	"devDependencies": {
		"@biomejs/biome": "^1.9",
		"@changesets/changelog-github": "^0.6.0",
		"@changesets/cli": "^2.30.0",
		"bun-types": "^1.2",
		"react-devtools-core": "^7.0.1",
		"turbo": "^2",
		"typescript": "^5.7"
	}
}
